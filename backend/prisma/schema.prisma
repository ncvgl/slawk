generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  status    String?  @default("online")
  bio       String?
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  messages           Message[]
  channels           ChannelMember[]
  reactions          Reaction[]
  files              File[]
  sentDMs            DirectMessage[] @relation("SentMessages")
  receivedDMs        DirectMessage[] @relation("ReceivedMessages")
  channelReads       ChannelRead[]
  bookmarks          Bookmark[]
  scheduledMessages  ScheduledMessage[]
}

model Channel {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())

  messages           Message[]
  members            ChannelMember[]
  reads              ChannelRead[]
  scheduledMessages  ScheduledMessage[]
}

model ChannelMember {
  userId    Int
  channelId Int
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
}

model Message {
  id        Int       @id @default(autoincrement())
  content   String
  userId    Int
  channelId Int
  threadId  Int?
  isPinned  Boolean   @default(false)
  pinnedBy  Int?
  pinnedAt  DateTime?
  editedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  user         User          @relation(fields: [userId], references: [id])
  channel      Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  reactions    Reaction[]
  files        File[]
  parent       Message?      @relation("MessageThread", fields: [threadId], references: [id])
  replies      Message[]     @relation("MessageThread")
  bookmarks    Bookmark[]
  channelReads ChannelRead[] @relation("ChannelReadMessage")

  @@index([channelId, createdAt])
  @@index([threadId])
}

model Reaction {
  id        Int      @id @default(autoincrement())
  emoji     String
  userId    Int
  messageId Int
  createdAt DateTime @default(now())

  user      User    @relation(fields: [userId], references: [id])
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId, emoji])
  @@index([messageId])
}

model File {
  id           Int      @id @default(autoincrement())
  filename     String
  originalName String
  mimetype     String
  size         Int
  url          String
  gcsPath      String?
  userId       Int
  messageId    Int?
  createdAt    DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  message   Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([messageId])
}

model DirectMessage {
  id         Int       @id @default(autoincrement())
  content    String
  fromUserId Int
  toUserId   Int
  threadId   Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
  editedAt   DateTime?
  deletedAt  DateTime?
  readAt     DateTime?

  fromUser   User             @relation("SentMessages", fields: [fromUserId], references: [id])
  toUser     User             @relation("ReceivedMessages", fields: [toUserId], references: [id])
  parent     DirectMessage?   @relation("DMThread", fields: [threadId], references: [id])
  replies    DirectMessage[]  @relation("DMThread")

  @@index([fromUserId, toUserId])
  @@index([toUserId, fromUserId])
  @@index([threadId])
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    Int
  messageId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([userId])
}

model ChannelRead {
  id                Int      @id @default(autoincrement())
  userId            Int
  channelId         Int
  lastReadMessageId Int?
  updatedAt         DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  lastReadMessage Message? @relation("ChannelReadMessage", fields: [lastReadMessageId], references: [id], onDelete: SetNull)

  @@unique([userId, channelId])
}

model ScheduledMessage {
  id          Int      @id @default(autoincrement())
  content     String
  channelId   Int
  userId      Int
  scheduledAt DateTime
  createdAt   DateTime @default(now())
  sent        Boolean  @default(false)

  user    User    @relation(fields: [userId], references: [id])
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([scheduledAt, sent])
  @@index([userId])
}
